# ==========================================
# REFENTRA - GLOBAL ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to '.env' in the root, or place 
# specific variables in their respective apps 
# (e.g., apps/api/.env and apps/web/.env.local)

# ─── 1. DATABASE CONFIGURATION (Prisma) ───
# URL for the PostgreSQL or SQLite database
# Example for PostgreSQL: postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public
# Example for SQLite: file:./dev.db
DATABASE_URL="file:../../packages/db/prisma/dev.db"

# ─── 2. AUTHENTICATION & SECURITY ───
# Secret key used for signing JWT tokens. Use a long random string.
JWT_SECRET="generate_a_random_secure_long_string_here_like_refentra-secret-base-key-24"
# Port for the NestJS Backend API
PORT=4000
# Backend API URL for the Frontend to connect
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── 3. EMAIL / SMTP CONFIGURATION ───
# Real-time OTP emails rely on these credentials.
# You can use services like Postmark, SendGrid, Amazon SES, or a standard Gmail / Outlook SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
# For Gmail, this should be an 'App Password', NOT your actual account password.
SMTP_PASS="your-app-password-or-smtp-key"
# The default "From" address for system emails
SMTP_FROM='"Refentra System" <no-reply@refentra.com>'

# ─── 4. CLOUD STORAGE (Resumes & Files) ───
# For optional cloud storage of resumes (AWS S3, Supabase, Cloudinary)
STORAGE_REGION="us-east-1"
STORAGE_BUCKET="refentra-resumes-bucket"
STORAGE_ACCESS_KEY="your-aws-access-key-id"
STORAGE_SECRET_KEY="your-aws-secret-access-key"
